# Copy to apps/backend/.env on VPS

DATABASE_URL=postgres://medusa:CHANGE_THIS_STRONG_PASSWORD@127.0.0.1:5432/medusa
REDIS_URL=redis://127.0.0.1:6379

# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_32_BYTES
COOKIE_SECRET=CHANGE_ME_GENERATE_RANDOM_32_BYTES
AUTH_MFA_ENCRYPTION_KEY=CHANGE_ME_GENERATE_RANDOM_32_BYTES

# Replace with your real domains (no trailing slash)
STORE_CORS=https://YOUR_DOMAIN,https://www.YOUR_DOMAIN
ADMIN_CORS=https://API_DOMAIN
AUTH_CORS=https://YOUR_DOMAIN,https://www.YOUR_DOMAIN,https://API_DOMAIN

DISABLE_MEDUSA_ADMIN=false
NODE_ENV=production
